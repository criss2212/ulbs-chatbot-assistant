# === Configurare API AI ===
# Cheia ta de la OpenAI (sau alt provider de LLM)
OPENAI_API_KEY=your_openai_api_key_here

# === Configurare Bază de Date Vectorială ===
# Calea către folderul unde ChromaDB își salvează datele (persist_directory)
CHROMA_DB_PATH=./data/processed/chroma_db
VECTOR_DB_HOST=db
VECTOR_DB_PORT=8000

# === Setări Aplicație ===
# Modul de rulare (development / production)
ENVIRONMENT=development
LOG_LEVEL=info
APP_PORT=8000

# === Configurare Bază de Date SQL (Dacă este cazul pentru Audit) ===
# Folosită pentru sistemul de Audit obligatoriu
DATABASE_URL=postgresql://user:password@localhost:5432/ulbs_chatbot_db